# OpenAlex polite-pool contact (used for higher rate limits)
OPENALEX_MAILTO=you@example.com

# University of Mississippi (Ole Miss) OpenAlex institution id
UM_INSTITUTION_ID=I368840534

# Postgres connection (compose sets host=db; for host-local runs use localhost)
DATABASE_URL=postgresql+psycopg://rex:rex@localhost:5432/researcher_explorer

HTTP_CONCURRENCY=8
MAX_COLLABORATORS_PER_AUTHOR=40

# --- Optional (sensible defaults in app/config.py) ---

# Importer snapshot path. Default /data/... suits Docker/Linux; on Windows use a
# Windows path, e.g. C:\rex\data\um_authors.jsonl
# SNAPSHOT_PATH=/data/um_authors.jsonl

# Connection pool, per uvicorn worker. Keep workers*(size+overflow) < Postgres
# max_connections (default 100).
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=5

# Max OpenAlex requests/sec, per process (polite pool allows ~10).
# OPENALEX_MAX_RPS=8

# Allowed CORS origins (comma-separated). Not needed when the frontend is served
# same-origin behind a reverse proxy.
# CORS_ALLOW_ORIGINS=https://researchers.example.edu
